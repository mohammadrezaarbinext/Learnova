{
  "name": "learnnova-backend",
  "version": "0.1.0",
  "private": true,
  "description": "LearnNova LMS backend",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "nest start --watch",
    "prestart:dev": "npm run db:prepare",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:deploy": "prisma generate && prisma db push",
    "db:prepare": "npm run prisma:generate && npm run db:push && npm run db:seed",
    "db:seed": "prisma db seed",
    "db:seed:test-data": "tsx prisma/seed-api-test-data.ts",
    "test:api:smoke": "tsx scripts/api-smoke-test.ts",
    "test:socket:smoke": "tsx scripts/socket-smoke-test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.43",
    "@types/passport-jwt": "^4.0.1",
    "@types/swagger-ui-express": "^4.1.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}