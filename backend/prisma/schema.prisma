generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum RoleName {
  ADMIN
  TEACHER
  STUDENT
  SUPPORT
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentRequestStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELED
}

enum PaymentTransactionStatus {
  SUCCESS
  FAILED
}

enum PaymentProvider {
  MOCK
}

model User {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid()) @db.Uuid
  fullName     String
  email        String?    @unique
  phone        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  wallet              Wallet?
  userRoles           UserRole[]
  courses             Course[]             @relation("CourseTeacher")
  enrollments         Enrollment[]         @relation("EnrollmentStudent")
  paymentRequests     PaymentRequest[]
  paymentTransactions PaymentTransaction[]
}

model Wallet {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @db.Uuid
  userId    Int      @unique
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  currency  String   @default("IRT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid()) @db.Uuid
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model UserRole {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @db.Uuid
  userId    Int
  roleId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid()) @db.Uuid
  roleId       Int
  permissionId Int
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Course {
  id           Int          @id @default(autoincrement())
  uuid         String       @unique @default(uuid()) @db.Uuid
  title        String
  description  String
  thumbnailUrl String?
  price        Decimal      @default(0) @db.Decimal(18, 2)
  level        CourseLevel
  status       CourseStatus @default(DRAFT)
  teacherId    Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  teacher             User                 @relation("CourseTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  videos              Video[]
  enrollments         Enrollment[]
  paymentRequests     PaymentRequest[]
  paymentTransactions PaymentTransaction[]
}

model Video {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.Uuid
  courseId        Int
  title           String
  description     String?
  videoUrl        String
  durationSeconds Int      @default(0)
  orderIndex      Int
  isFree          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @db.Uuid
  studentId Int
  courseId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student User   @relation("EnrollmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model PaymentRequest {
  id          Int                  @id @default(autoincrement())
  uuid        String               @unique @default(uuid()) @db.Uuid
  userId      Int
  courseId    Int
  amount      Decimal              @db.Decimal(18, 2)
  currency    String               @default("IRT")
  status      PaymentRequestStatus @default(PENDING)
  provider    PaymentProvider      @default(MOCK)
  description String?
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  transactions PaymentTransaction[]

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model PaymentTransaction {
  id                  Int                      @id @default(autoincrement())
  uuid                String                   @unique @default(uuid()) @db.Uuid
  paymentRequestId    Int
  userId              Int
  courseId            Int
  amount              Decimal                  @db.Decimal(18, 2)
  currency            String                   @default("IRT")
  status              PaymentTransactionStatus
  provider            PaymentProvider          @default(MOCK)
  providerAuthority   String?
  providerReferenceId String?
  rawRequest          Json?
  rawResponse         Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  paymentRequest PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([paymentRequestId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}
