generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum RoleName {
  ADMIN
  TEACHER
  STUDENT
  SUPPORT
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentRequestStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELED
}

enum PaymentTransactionStatus {
  SUCCESS
  FAILED
}

enum PaymentProvider {
  MOCK
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  MULTIPLE_CHOICE
  DESCRIPTIVE
}

enum QuestionContentType {
  TEXT
  IMAGE
  RICH_TEXT
}

enum QuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  EXPIRED
}

model User {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid()) @db.Uuid
  fullName     String
  email        String?    @unique
  phone        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  wallet              Wallet?
  userRoles           UserRole[]
  courses             Course[]             @relation("CourseTeacher")
  enrollments         Enrollment[]         @relation("EnrollmentStudent")
  paymentRequests     PaymentRequest[]
  paymentTransactions PaymentTransaction[]
  quizAttempts        QuizAttempt[]        @relation("QuizAttemptStudent")
}

model Wallet {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @db.Uuid
  userId    Int      @unique
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  currency  String   @default("IRT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid()) @db.Uuid
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model UserRole {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @db.Uuid
  userId    Int
  roleId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid()) @db.Uuid
  roleId       Int
  permissionId Int
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Course {
  id           Int          @id @default(autoincrement())
  uuid         String       @unique @default(uuid()) @db.Uuid
  title        String
  description  String
  thumbnailUrl String?
  price        Decimal      @default(0) @db.Decimal(18, 2)
  level        CourseLevel
  status       CourseStatus @default(DRAFT)
  teacherId    Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  teacher             User                 @relation("CourseTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  videos              Video[]
  enrollments         Enrollment[]
  paymentRequests     PaymentRequest[]
  paymentTransactions PaymentTransaction[]
  quizzes             Quiz[]
}

model Video {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.Uuid
  courseId        Int
  title           String
  description     String?
  videoUrl        String
  durationSeconds Int      @default(0)
  orderIndex      Int
  isFree          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @db.Uuid
  studentId Int
  courseId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student User   @relation("EnrollmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model PaymentRequest {
  id          Int                  @id @default(autoincrement())
  uuid        String               @unique @default(uuid()) @db.Uuid
  userId      Int
  courseId    Int
  amount      Decimal              @db.Decimal(18, 2)
  currency    String               @default("IRT")
  status      PaymentRequestStatus @default(PENDING)
  provider    PaymentProvider      @default(MOCK)
  description String?
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  transactions PaymentTransaction[]

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model PaymentTransaction {
  id                  Int                      @id @default(autoincrement())
  uuid                String                   @unique @default(uuid()) @db.Uuid
  paymentRequestId    Int
  userId              Int
  courseId            Int
  amount              Decimal                  @db.Decimal(18, 2)
  currency            String                   @default("IRT")
  status              PaymentTransactionStatus
  provider            PaymentProvider          @default(MOCK)
  providerAuthority   String?
  providerReferenceId String?
  rawRequest          Json?
  rawResponse         Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  paymentRequest PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([paymentRequestId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model Quiz {
  id              Int        @id @default(autoincrement())
  uuid            String     @unique @default(uuid()) @db.Uuid
  courseId        Int
  title           String
  description     String?
  durationMinutes Int        @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  status          QuizStatus @default(DRAFT)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([status])
}

model Question {
  id          Int                 @id @default(autoincrement())
  uuid        String              @unique @default(uuid()) @db.Uuid
  quizId      Int
  type        QuestionType
  contentType QuestionContentType @default(TEXT)
  content     Json
  imageUrl    String?
  points      Decimal             @default(1) @db.Decimal(10, 2)
  orderIndex  Int
  answerKey   Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  quiz    Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers QuestionAnswer[]

  @@index([quizId])
  @@index([type])
}

model QuestionOption {
  id          Int                 @id @default(autoincrement())
  uuid        String              @unique @default(uuid()) @db.Uuid
  questionId  Int
  contentType QuestionContentType @default(TEXT)
  content     Json
  imageUrl    String?
  orderIndex  Int
  isCorrect   Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  question Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  QuestionAnswer[]

  @@index([questionId])
}

model QuizAttempt {
  id          Int               @id @default(autoincrement())
  uuid        String            @unique @default(uuid()) @db.Uuid
  quizId      Int
  studentId   Int
  startedAt   DateTime          @default(now())
  submittedAt DateTime?
  status      QuizAttemptStatus @default(IN_PROGRESS)
  score       Decimal?          @db.Decimal(10, 2)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  quiz    Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student User             @relation("QuizAttemptStudent", fields: [studentId], references: [id], onDelete: Cascade)
  answers QuestionAnswer[]

  @@index([quizId])
  @@index([studentId])
  @@index([status])
}

model QuestionAnswer {
  id                Int                  @id @default(autoincrement())
  uuid              String               @unique @default(uuid()) @db.Uuid
  attemptId         Int
  questionId        Int
  selectedOptionId  Int?
  answerContentType QuestionContentType?
  answerContent     Json?
  answerImageUrl    String?
  score             Decimal?             @db.Decimal(10, 2)
  isCorrect         Boolean?
  gradedAt          DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  attempt        QuizAttempt    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption QuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@index([selectedOptionId])
}
